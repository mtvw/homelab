---
services:
{% if docker_traefik_enabled %}
  traefik:
    image: {{ docker_traefik_image }}
    container_name: traefik
    command:
      - --api.dashboard=true
      - --api.insecure={{ docker_traefik_dashboard_insecure | string | lower }}
      - --entrypoints.web.address=:80
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    ports:
      - "{{ docker_traefik_http_port }}:80"
      - "{{ docker_traefik_dashboard_port }}:8080"
    restart: unless-stopped

{% endif %}
{% if docker_watchtower_enabled %}
  watchtower:
    image: {{ docker_watchtower_image }}
    container_name: watchtower
    environment:
      TZ: {{ docker_stack_timezone }}
      WATCHTOWER_MONITOR_ONLY: "true"
      WATCHTOWER_SCHEDULE: {{ docker_watchtower_schedule | quote }}
{% if docker_watchtower_notification_url | length > 0 %}
      WATCHTOWER_NOTIFICATION_URL: {{ docker_watchtower_notification_url | quote }}
{% endif %}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    restart: unless-stopped

{% endif %}
{% if docker_wud_enabled %}
  wud:
    image: {{ docker_wud_image }}
    container_name: wud
    environment:
      TZ: {{ docker_stack_timezone }}
      WUD_SERVER_PORT: "3000"
      WUD_WATCHER_LOCAL_SOCKET: /var/run/docker.sock
      WUD_WATCHER_LOCAL_CRON: {{ docker_wud_schedule | quote }}
      WUD_WATCHER_LOCAL_WATCHBYDEFAULT: "true"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ docker_stack_config_path }}/wud:/store
    ports:
      - "{{ docker_wud_port }}:3000"
{% if docker_traefik_enabled %}
    labels:
      traefik.enable: "true"
      traefik.http.routers.wud.entrypoints: web
      traefik.http.routers.wud.rule: "Host(`{{ docker_wud_traefik_host }}`)"
      traefik.http.services.wud.loadbalancer.server.port: "3000"
{% endif %}
    restart: unless-stopped

{% endif %}
{% for service in docker_media_services %}
  {{ service.name }}:
    image: {{ service.image }}
    container_name: {{ service.name }}
{% if service.init | default(false) %}
    init: true
{% endif %}
    environment:
{% if service.include_stack_ids | default(true) %}
      PUID: "{{ docker_stack_puid }}"
      PGID: "{{ docker_stack_pgid }}"
{% endif %}
      TZ: {{ docker_stack_timezone }}
{% for key, value in service.environment | default({}) | dictsort %}
      {{ key }}: {{ value | quote }}
{% endfor %}
    volumes:
      - {{ docker_stack_config_path }}/{{ service.config_subdir }}:{{ service.config_mount_path | default('/config') }}
{% if service.mount_media | default(true) %}
      - {{ docker_media_path }}:/media
{% endif %}
{% if service.mount_downloads | default(true) %}
      - {{ docker_downloads_path }}:/downloads
{% endif %}
{% if service.mount_docker_socket | default(false) %}
      - /var/run/docker.sock:/var/run/docker.sock:ro
{% endif %}
    ports:
      - "{{ service.port }}:{{ service.port }}"
{% if docker_traefik_enabled and (service.traefik_host is defined or service.traefik_extra_hosts is defined) %}
{% set traefik_hosts = ([service.traefik_host] if service.traefik_host is defined else []) + (service.traefik_extra_hosts | default([])) %}
    labels:
      traefik.enable: "true"
      traefik.http.routers.{{ service.name }}.entrypoints: web
      traefik.http.routers.{{ service.name }}.rule: "{% for host in traefik_hosts %}Host(`{{ host }}`){% if not loop.last %} || {% endif %}{% endfor %}"
      traefik.http.services.{{ service.name }}.loadbalancer.server.port: "{{ service.port }}"
{% endif %}
{% if service.healthcheck is defined %}
    healthcheck:
      test: {{ service.healthcheck.test | quote }}
      start_period: {{ service.healthcheck.start_period }}
      timeout: {{ service.healthcheck.timeout }}
      interval: {{ service.healthcheck.interval }}
      retries: {{ service.healthcheck.retries }}
{% endif %}
    restart: unless-stopped
{% endfor %}
