---
# Copy this file to vault.yml and encrypt it with:
# ansible-vault encrypt ansible/group_vars/docker_hosts/vault.yml
#
# Keep the Vault password outside this repository.

docker_homepage_jellyfin_api_key: "replace-with-jellyfin-api-key"
docker_homepage_radarr_api_key: "replace-with-radarr-api-key"
docker_homepage_sonarr_api_key: "replace-with-sonarr-api-key"
docker_homepage_sabnzbd_api_key: "replace-with-sabnzbd-api-key"
docker_homepage_prowlarr_api_key: "replace-with-prowlarr-api-key"
docker_homepage_seerr_api_key: "replace-with-seerr-api-key"
docker_homepage_readarr_api_key: "replace-with-readarr-api-key"
docker_homepage_audiobookshelf_api_key: "replace-with-audiobookshelf-api-key"

docker_homepage_proxmox_username: "replace-with-proxmox-user-or-token-id"
docker_homepage_proxmox_password: "replace-with-proxmox-password-or-token-secret"

docker_homepage_pbs_username: "replace-with-pbs-user-or-token-id"
docker_homepage_pbs_password: "replace-with-pbs-password-or-token-secret"
